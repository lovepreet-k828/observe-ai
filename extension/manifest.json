{
  "manifest_version": 3,
  "name": "ObserveAI",
  "version": "1.2.0",
  "description": "Record, review, highlight, approve, and locally run browser workflows with polished Ghost Mode UX.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "recorder.js"
      ],
      "run_at": "document_start"
    }
  ]
}